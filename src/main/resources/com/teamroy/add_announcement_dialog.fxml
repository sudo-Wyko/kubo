<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.AddAnnouncementDialogController"
      spacing="12" prefWidth="440"
      styleClass="content-view dialog-root card">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <Label text="Create announcement" styleClass="dialog-title"/>

    <VBox spacing="6">
        <Label text="Title"/>
        <TextField fx:id="titleField" styleClass="form-control"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Message"/>
        <TextArea fx:id="messageField" prefRowCount="5" wrapText="true" styleClass="form-control"/>
    </VBox>

    <Label fx:id="errorLabel" styleClass="error-label" wrapText="true" visible="false" managed="false"/>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel" styleClass="secondary-button"/>
        <Button fx:id="saveButton" text="Publish" onAction="#confirm" styleClass="primary-button"/>
    </HBox>
</VBox>
