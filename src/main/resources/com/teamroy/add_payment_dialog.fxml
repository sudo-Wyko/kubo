<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.AddPaymentDialogController"
      spacing="12" prefWidth="420">
    <padding>
        <Insets top="20" right="24" bottom="20" left="24"/>
    </padding>

    <Label text="Record payment" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <VBox spacing="6">
        <Label text="Tenant"/>
        <ComboBox fx:id="tenantCombo" maxWidth="Infinity"/>
        <Label fx:id="tenantLockedLabel" visible="false" managed="false"
               style="-fx-font-weight: bold;"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Amount"/>
        <TextField fx:id="amountField" promptText="0.00"/>
        <Label fx:id="amountErrorLabel" style="-fx-text-fill: #dc2626;" wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Payment date"/>
        <DatePicker fx:id="paymentDatePicker" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Method"/>
        <ComboBox fx:id="methodCombo" maxWidth="Infinity"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Status"/>
        <ComboBox fx:id="statusCombo" maxWidth="Infinity"/>
        <Label fx:id="statusLockedLabel" visible="false" managed="false"/>
    </VBox>

    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel"/>
        <Button fx:id="saveButton" text="Save" onAction="#confirm"
                styleClass="btn-primary"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
