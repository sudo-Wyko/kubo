<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.AddTenantDialogController"
      spacing="12" prefWidth="420">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
    <Label fx:id="titleLabel" text="Add tenant" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="First name *"/>
    <TextField fx:id="firstNameField"/>
    <Label text="Last name *"/>
    <TextField fx:id="lastNameField"/>
    <Label text="Contact number"/>
    <TextField fx:id="contactField"/>
    <Label text="Email"/>
    <TextField fx:id="emailField"/>
    <Separator/>
    <Label text="Username (creates tenant login)" style="-fx-text-fill: #94a3b8;"/>
    <TextField fx:id="usernameField" promptText="Optional"/>
    <Label text="Temporary password"/>
    <PasswordField fx:id="passwordField" promptText="Required if username is set"/>
    <Label fx:id="errorLabel" managed="false" visible="false" wrapText="true" style="-fx-text-fill: #dc2626;"/>
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel"/>
        <Button fx:id="saveButton" text="Save" onAction="#save"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
