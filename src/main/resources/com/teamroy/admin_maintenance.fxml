<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teamroy.controller.AdminMaintenanceController"
            style="-fx-background-color: #0a0a0a;">
    <padding>
        <Insets top="16" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" style="-fx-padding: 0 0 12 0;">
            <ComboBox fx:id="roomFilterCombo" promptText="By Room" prefWidth="200"/>
            <ComboBox fx:id="statusFilterCombo" promptText="By Status" prefWidth="180"/>
            <DatePicker fx:id="dateFilterPicker" promptText="By Date"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="16" alignment="TOP_CENTER">
            <VBox fx:id="columnTotal" spacing="10" prefWidth="260" HBox.hgrow="ALWAYS">
                <Label text="Total Requests" maxWidth="Infinity" alignment="CENTER"
                       style="-fx-background-color: #475569; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox fx:id="kanbanTotalBody" spacing="12" style="-fx-padding: 8;"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="columnOpen" spacing="10" prefWidth="260" HBox.hgrow="ALWAYS">
                <Label text="Open Requests" maxWidth="Infinity" alignment="CENTER"
                       style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox fx:id="kanbanOpenBody" spacing="12" style="-fx-padding: 8;"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="columnUrgent" spacing="10" prefWidth="260" HBox.hgrow="ALWAYS">
                <Label text="Urgent Requests" maxWidth="Infinity" alignment="CENTER"
                       style="-fx-background-color: #ea580c; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox fx:id="kanbanUrgentBody" spacing="12" style="-fx-padding: 8;"/>
                </ScrollPane>
            </VBox>

            <VBox fx:id="columnCompleted" spacing="10" prefWidth="260" HBox.hgrow="ALWAYS">
                <Label text="Completed" maxWidth="Infinity" alignment="CENTER"
                       style="-fx-background-color: #15803d; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-font-weight: bold;"/>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
                    <VBox fx:id="kanbanCompletedBody" spacing="12" style="-fx-padding: 8;"/>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
