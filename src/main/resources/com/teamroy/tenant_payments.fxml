<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox spacing="20" styleClass="content-view"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.TenantPaymentsController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Payments" styleClass="payments-header"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="statusFilter" promptText="Filter by Status"/>
        <Button fx:id="addPaymentBtn" text="+ Add Payment" onAction="#handleAddPayment"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="main-scroll-pane" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="paymentGrid" hgap="30" vgap="40" styleClass="content-view"/>
    </ScrollPane>
</VBox>
