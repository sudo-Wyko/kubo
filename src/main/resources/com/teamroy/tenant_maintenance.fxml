<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<VBox spacing="20" styleClass="content-view"
      xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.TenantMaintenanceController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="Maintenance Requests" styleClass="payments-header"/>
        <Region HBox.hgrow="ALWAYS"/>
        <ComboBox fx:id="statusFilter" promptText="Filter by Status"/>
        <Button text="+ New Request" onAction="#handleAddRequest" styleClass="payments-add-btn"/>
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="main-scroll-pane" VBox.vgrow="ALWAYS">
        <VBox fx:id="requestList" spacing="15" styleClass="content-view"/>
    </ScrollPane>
</VBox>