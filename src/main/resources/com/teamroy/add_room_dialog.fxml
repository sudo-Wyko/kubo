<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.teamroy.controller.AddRoomDialogController"
      spacing="12" prefWidth="420">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
    <Label fx:id="titleLabel" text="Add room" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
    <Label text="Room number *"/>
    <TextField fx:id="roomNumberField" promptText="e.g., 301"/>
    <Label text="Room type *"/>
    <ComboBox fx:id="typeCombo" maxWidth="Infinity"/>
    <Label text="Capacity *"/>
    <TextField fx:id="capacityField" promptText="Beds"/>
    <Label text="Price / month"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="₱" style="-fx-text-fill: #cbd5f5; -fx-font-weight: bold;"/>
        <TextField fx:id="priceField" promptText="0.00" HBox.hgrow="ALWAYS"/>
    </HBox>
    <Label fx:id="errorLabel" managed="false" visible="false" wrapText="true" style="-fx-text-fill: #dc2626;"/>
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#cancel"/>
        <Button fx:id="saveButton" text="Save" onAction="#save"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold;"/>
    </HBox>
</VBox>
