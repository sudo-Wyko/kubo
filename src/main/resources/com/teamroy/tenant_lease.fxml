<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" styleClass="main-scroll-pane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teamroy.controller.TenantLeaseController">

    <VBox fx:id="leaseListContainer" spacing="24" styleClass="content-view">
        <padding>
            <Insets top="30" right="30" bottom="30" left="30"/>
        </padding>

        <Label fx:id="headerLabel" text="Lease Details" styleClass="payments-header"/>
        <Label fx:id="emptyStateLabel" text="No lease history on file."
               styleClass="card-subtitle" visible="false" managed="false"/>
    </VBox>
</ScrollPane>
