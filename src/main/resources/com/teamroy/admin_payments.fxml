<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.teamroy.controller.AdminPaymentController"
            styleClass="content-view page-root">
    <padding>
        <Insets top="16" right="20" bottom="20" left="20"/>
    </padding>

    <top>
        <VBox spacing="12">
            <StackPane prefHeight="140" styleClass="card card-compact">
                <Label text="Payments overview — chart placeholder"
                       styleClass="card-subtitle"/>
            </StackPane>

            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="page-toolbar">
                <Label text="Payments" styleClass="page-title"/>
                <ComboBox fx:id="tenantFilterCombo" promptText="All Tenants" prefWidth="180" styleClass="form-control"/>
                <ComboBox fx:id="statusFilterCombo" promptText="By Status" prefWidth="160" styleClass="form-control"/>
                <DatePicker fx:id="monthFilterPicker" promptText="By Month" styleClass="form-control"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Export CSV" onAction="#handleExportPaymentsCsv"
                        styleClass="secondary-button"/>
                <Button text="Export JSON" onAction="#handleExportPaymentsJson"
                        styleClass="secondary-button"/>
                <Button text="+ Add New Payment" onAction="#handleAddPayment"
                        styleClass="primary-button"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="10">
            <HBox spacing="12" alignment="CENTER_LEFT">
                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card dashboard-stat pending-stat">
                    <Label text="Pending volume" styleClass="card-subtitle"/>
                    <Label fx:id="pendingCardLabel" text="₱0.00" styleClass="card-title"/>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card dashboard-stat verified-stat">
                    <Label text="Verified volume" styleClass="card-subtitle"/>
                    <Label fx:id="verifiedCardLabel" text="₱0.00" styleClass="card-title"/>
                </VBox>
                <VBox spacing="8" HBox.hgrow="ALWAYS" styleClass="card dashboard-stat failed-stat">
                    <Label text="Failed volume" styleClass="card-subtitle"/>
                    <Label fx:id="failedCardLabel" text="₱0.00" styleClass="card-title"/>
                </VBox>
            </HBox>

            <VBox styleClass="card" VBox.vgrow="ALWAYS">
            <TableView fx:id="paymentTable" VBox.vgrow="ALWAYS" styleClass="table-clean">
                <columns>
                    <TableColumn fx:id="colPaymentId" text="Payment ID" prefWidth="90"/>
                    <TableColumn fx:id="colTenant" text="Tenant" prefWidth="160"/>
                    <TableColumn fx:id="colAmount" text="Amount" prefWidth="120"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="140"/>
                    <TableColumn fx:id="colMethod" text="Method" prefWidth="120"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="120"/>
                    <TableColumn fx:id="colActions" text="Actions" prefWidth="140"/>
                </columns>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card card-compact">
                <Label text="Verified total (filtered):" styleClass="card-subtitle"/>
                <Label fx:id="verifiedTotalLabel" text="₱0.00" styleClass="balance-label"/>
            </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
